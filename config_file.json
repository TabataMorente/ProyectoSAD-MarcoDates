{
    "target": "abandono",
    "method": "knn",
    "task": "classification",
    "evaluation": "macro",
    "hyperparameters_knn": {
        "k_range": [1, 5],
        "p": [1, 2],
        "weights": ["uniform", "distance"],
        "step": 2
    },
    "hyperparameters_tree": {
        "max_depth": [3, 5, 10],
        "criterio": ["gini", "entropy"]
    },
    "hyperparameters_bayes": {
        "var_smoothing": [1e-9, 1e-7, 1e-5],
        "bayes_type": "multinomial",
        "alpha": [0.1, 0.5, 1.0, 2.0]
    },
    "hyperparameters_forest": {
        "n_estimators": [50, 100, 200],
        "max_depth": [3, 5, 10],
        "max_features": ["sqrt", "log2"]
    },
    "preprocessing": {
        "drop_duplicates": true,
        "drop_columns": [""],
        "text_features": [],
        "text_process_method": "none",
        "language": "spanish",
        "categorical_features": ["plan", "genero"],
        "boolean_features": ["soporte_premium"],
        "missing_values": "impute",
        "impute_strategy": "mean",
        "outliers": "clip",
        "discretize_features": [],
        "discretize_bins": 3,
        "scaling": "max-min",
        "sampling_strategy": "oversample",
        "erroneous_values": {
            "action": "impute",
            "rules": {
                "meses_permanencia": {
                    "conditions": [{"type": "less_than", "value": 0}],
                    "strategy": "median"
                },
                "genero": {
                    "conditions": [
                        {"type": "equals", "value": "."},
                        {"type": "in_list", "value": ["NA", "N/A", "null"]}
                    ],
                    "strategy": "mode"
                }
            }
        }
    }
}
{
   "target": "score",
   "method": "bayes",
   "task": "clustering",
   "evaluation": "macro",
   "hyperparameters_knn": {
       "k_range": [3, 10],
       "step": 2,
       "p": [1,2],
       "weights": ["uniform", "distance"]
   },
   "hyperparameters_tree": {
       "max_depth": [3, 5, 10],
       "criterio": ["gini", "entropy"]
   },
   "hyperparameters_bayes": {
       "var_smoothing": [1e-9, 1e-7, 1e-5],
       "bayes_type": "multinomial",
       "alpha": [0.1, 0.5, 1.0, 2.0]
   },
   "hyperparameters_forest": {
       "n_estimators": [100, 200],
       "max_depth": [3, 5, 10, 20, null],
       "max_features": ["sqrt", "log2"]
   },
   "hyperparameters_logistic": {
       "C": [0.01, 0.1, 1.0, 10.0],
       "solver": ["lbfgs"]
   },
   "preprocessing": {
       "drop_duplicates": true,
       "drop_columns": ["reviewId"],
       "text_features": ["content"],
       "text_process_method": "tf-idf",
       "ngram_range": [1, 1],
       "limite_palabras": "none",
       "language": "english",
       "categorical_features": ["gender"],
       "categorical_encoding": "one-hot",
       "boolean_features": [],
       "missing_values": "impute",
       "impute_strategy": "most_frequent",
       "outliers": "clip",
       "discretize_features": [],
       "discretize_bins": 3,
       "scaling": "min-max",
       "sampling_strategy": "none",
       "sampling_ratio": {"0": 3000, "1":1000, "2": 2500},
       "erroneous_values": {
           "action": "impute",
           "rules": {}
       }
   },
  "prompt_engineering" : {
    "mode" : "sentiment_analysis",
    "model" : "gemma2:2b",
    "possible_answers": ["Worst", "Bad", "Neutral", "Good", "Best"],
    "temperature": 0,
    "repeat_penalty": 1.0,
    "num_predict": 1,
    "top_k": 10,
    "top_p": 0.5
  },
  "clustering_lda": {
       "n_components_range": [2, 3, 4, 5, 6, 7, 8, 9, 10],
       "learning_method": ["batch"],
       "max_iter": [10, 20],
       "doc_topic_prior": [null, 0.1, 0.5],
       "topic_word_prior": [null, 0.1, 0.5]
   }
}
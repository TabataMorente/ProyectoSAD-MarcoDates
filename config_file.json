{
    "target": "v1",
    "method": "knn",
    "task": "classification",
    "evaluation": "macro",
    "hyperparameters_knn":{
        "k_range": [1, 3],
        "p": [1, 2],
        "weights": ["uniform", "distance"],
        "step": 2
    },
    "hyperparameters_tree":{
        "max_depth": [3, 5, 10],
        "criterio": ["gini", "entropy"]
    },
    "hyperparameters_bayes": {
        "var_smoothing": [1e-9, 1e-7, 1e-5],
        "bayes_type": "multinomial",
        "alpha": [0.1, 0.5, 1.0, 2.0]
    },
    "hyperparameters_forest":{
        "n_estimators": [50, 100, 200],
        "max_depth": [3, 5, 10],
        "max_features": ["sqrt", "log2"]
    },
    "preprocessing":{
        "categorical_features":[],
        "text_features": ["v2"],
        "boolean_features": [],
        "missing_values": "impute",
        "impute_strategy": "mean",
        "discretize_features": [],
        "discretize_bins": 3,
        "scaling": "max-min",
        "text_process": "one-hot",
        "sampling": "none"
    }
}